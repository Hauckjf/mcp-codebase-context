{
  "name": "mcp-codebase-context",
  "version": "0.1.0",
  "description": "Exposes a local codebase as structured tools for Claude agents \u2013 symbol search, file tree, git history, and dependency graphs.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src tests",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "codebase",
    "context",
    "claude"
  ],
  "author": "Hauckjf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hauckjf/mcp-codebase-context.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "execa": "^9.4.0",
    "ignore": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^9.0.0",
    "typescript": "^6.0.3",
    "vitest": "^1.0.4"
  }
}
