{
  "name": "mcp-codebase-context",
  "version": "0.1.0",
  "description": "MCP server exposing a local codebase as structured tools for Claude agents",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "mcp-codebase-context": "dist/index.js"
  },
