    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "mcp",
